rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── JOBS ──────────────────────────────────────────────────────────────────
    // Reads are open so share links (punch, home runs, questions, lighting)
    // work without login. Writes are validated lightly to prevent garbage data,
    // but we accept the actual shape the client sends: updated_at is an ISO
    // string (new Date().toISOString()), NOT a Firestore Timestamp — the app
    // has always written it that way. If a write lands without data/updated_at
    // that's almost certainly a bug or an attack, so we still require them.
    match /jobs/{jobId} {
      allow read: if true;

      allow write: if request.resource.data.keys().hasAll(['data', 'updated_at'])
                   && request.resource.data.data is map
                   && request.resource.data.updated_at is string;
      // The write rule only fires for create/update — delete passes a null
      // resource and would otherwise fail the key check. Allow it explicitly
      // so the app's job-archive path keeps working.
      allow delete: if true;
    }

    // ── MANUAL TASKS ──────────────────────────────────────────────────────────
    // Ad-hoc task list outside the job records. Same shape as /jobs (data map
    // + ISO updated_at string), so we apply the same light validation.
    match /manualTasks/{taskId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasAll(['data', 'updated_at'])
                   && request.resource.data.data is map
                   && request.resource.data.updated_at is string;
      allow delete: if true;
    }

    // ── QUOTE WALKS ───────────────────────────────────────────────────────────
    // Pre-job site walk notes (replaces Apple Notes capture). Same shape as
    // /jobs and /manualTasks — data map + ISO updated_at string. UI-level
    // permission checks handle who sees walks (admin + foreman roles).
    match /quoteWalks/{walkId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasAll(['data', 'updated_at'])
                   && request.resource.data.data is map
                   && request.resource.data.updated_at is string;
      allow delete: if true;
    }

    // Redline walks — same envelope + validation as /quoteWalks (data map + ISO
    // updated_at string). UI-level permission controls who edits.
    match /redlineWalks/{walkId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasAll(['data', 'updated_at'])
                   && request.resource.data.data is map
                   && request.resource.data.updated_at is string;
      allow delete: if true;
    }

    // ── HOMEOWNER REQUESTS ────────────────────────────────────────────────────
    // Share link recipients submit answers here — allow creates from anyone.
    // Only the app reads these back, so reads are also open for now.
    match /homeowner_requests/{docId} {
      // Share-link recipients submit AND resubmit answers here; the app also
      // writes gen-load + lighting-collab requests to the same doc. Validate
      // lightly (jobId must be a string, consistent with /jobs) and allow
      // updates so resubmits/edits work. Never allow deletes.
      allow read: if true;
      allow create: if request.resource.data.jobId is string;
      allow update: if request.resource.data.jobId is string;
      allow delete: if false;

      // ── VERSION SNAPSHOTS (Kweller hardening Layer 4, 2026-07-09) ────────
      // Point-in-time copies stashed by saveHomeownerRequest() before every
      // write (public share pages AND internal app), so a bad merge or
      // overwrite is a 2-minute restore instead of a loss. Same open posture
      // as the parent doc — no auth model to gate on. Immutable once written
      // (no update); delete allowed so the client can prune to the last 10.
      match /versions/{versionId} {
        allow read: if true;
        allow create: if true;
        allow update: if false;
        allow delete: if true;
      }
    }

    // ── QUESTION SHARES ───────────────────────────────────────────────────────
    // Stores live share sessions for the Questions share feature.
    // Reads are open so recipients can see which questions are included.
    // Creates are open so the app can generate new sessions.
    // Updates allowed so the sender can add/remove questions after the fact.
    match /question_shares/{shareId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['jobId', 'questionIds', 'createdAt'])
                    && request.resource.data.jobId is string
                    && request.resource.data.questionIds is list;
      allow update: if request.resource.data.keys().hasAll(['questionIds', 'updatedAt'])
                    && request.resource.data.questionIds is list;
      allow delete: if false;
    }

    // ── SETTINGS ──────────────────────────────────────────────────────────────
    // Shared app settings (user list, scoreboard weight defaults, etc).
    // Reads are open so the app can bootstrap without login. Writes are open
    // in the same spirit as /jobs — the app protects these with UI-level
    // permission checks rather than Firestore auth (consistent with how the
    // rest of the app works today).
    match /settings/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── CONFIG ────────────────────────────────────────────────────────────────
    // App-wide config flags (e.g. force-update version). Same read/write
    // posture as /settings.
    match /config/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── SUGGESTIONS ───────────────────────────────────────────────────────────
    // Crew-submitted feature requests / bug reports / improvements, surfaced
    // on the App Map tab. Creates accepted from anyone (anonymous OK so the
    // share URL can also collect — though current UI only shows the form
    // when logged in). Reads open so admin/manager can see the inbox.
    // Updates allowed (Koy changes status + notes during triage). Deletes
    // allowed so cleared / spammy entries can be removed.
    match /suggestions/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['text', 'submittedAt', 'status'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() < 5000;
      allow update: if true;
      allow delete: if true;
    }

    // ── NEEDS BOARD ───────────────────────────────────────────────────────────
    // Coordinator board for deadline-bound contractor call-in needs. Same shape
    // as /manualTasks and /quoteWalks (data map + ISO updated_at string), so the
    // same light validation applies. UI-level board.add permission controls who
    // can write; reads open to match the rest of the app.
    match /needs/{needId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasAll(['data', 'updated_at'])
                   && request.resource.data.data is map
                   && request.resource.data.updated_at is string;
      allow delete: if true;
    }

    // ── NOTIFICATION INBOX ────────────────────────────────────────────────────
    // Per-user in-app notification inbox: notifications/{userKey}/items/{id}.
    // ONLY Cloud Functions create these (admin SDK bypasses rules), so client
    // creates are denied. Clients may read, flip the read flag (and nothing
    // else — enforced via affectedKeys), and delete (clear) their items.
    // Reads open to match the rest of the app's posture (UI scopes by user).
    match /notifications/{userKey}/items/{itemId} {
      allow read: if true;
      allow create: if false;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if true;
    }

    // ── EVERYTHING ELSE ───────────────────────────────────────────────────────
    // Deny all access to any other collection by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
